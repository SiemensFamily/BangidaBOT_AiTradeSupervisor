# Crypto Scalper — Exchange API Keys
# Copy this to .env and fill in your credentials

# Binance Futures
SCALPER__EXCHANGES__BINANCE__API_KEY=
SCALPER__EXCHANGES__BINANCE__API_SECRET=

# Bybit V5
SCALPER__EXCHANGES__BYBIT__API_KEY=
SCALPER__EXCHANGES__BYBIT__API_SECRET=

# OKX
SCALPER__EXCHANGES__OKX__API_KEY=
SCALPER__EXCHANGES__OKX__API_SECRET=
SCALPER__EXCHANGES__OKX__PASSPHRASE=

# Kraken Futures
SCALPER__EXCHANGES__KRAKEN__API_KEY=
SCALPER__EXCHANGES__KRAKEN__API_SECRET=

# Logging
RUST_LOG=info
